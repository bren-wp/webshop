# ============================================================
# ĐurđaShop — Apache konfiguracija
# NAPOMENA: namjerno BEZ "Options" direktiva — mnogi shared hostingi
# ih ne dopuštaju u .htaccess pa bi cijela trgovina pala na 500.
# Listanje direktorija sprječavaju prazni index.html u uploads/.
# ============================================================

# Blokiraj skrivene datoteke (.git, .env, .lock…) i osjetljive datoteke/arhive
<FilesMatch "^\.">
    Require all denied
</FilesMatch>
<FilesMatch "\.(sql|log|md|lock|sample\.php|env|ini|yml|yaml|bak|backup|old|orig|save|swp|zip|tar|gz|tgz|7z|rar|sh)$">
    Require all denied
</FilesMatch>
<FilesMatch "^(composer\.(json|lock)|package(-lock)?\.json|config\.php)$">
    Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Lijepi URL-ovi (rade i u poddirektoriju — relativna pravila)
    RewriteRule ^p/([a-z0-9-]+)/?$ proizvod.php?slug=$1 [L,QSA]
    RewriteRule ^k/([a-z0-9-]+)/?$ proizvodi.php?cat=$1 [L,QSA]
    RewriteRule ^s/([a-z0-9-]+)/?$ stranica.php?slug=$1 [L,QSA]
    RewriteRule ^blog/?$ blog.php [L,QSA]
    RewriteRule ^blog/([a-z0-9-]+)/?$ clanak.php?slug=$1 [L,QSA]
    RewriteRule ^sitemap\.xml$ sitemap.php [L]
    RewriteRule ^robots\.txt$ robots.php [L]
    RewriteRule ^llms\.txt$ llms.php [L]
</IfModule>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Keširanje statike
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 180 days"
    ExpiresByType image/png "access plus 180 days"
    ExpiresByType image/webp "access plus 180 days"
    ExpiresByType image/svg+xml "access plus 180 days"
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
</IfModule>

# Kompresija (ako hosting podržava) — manji prijenos, brže učitavanje
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml application/javascript application/json image/svg+xml
</IfModule>

AddDefaultCharset utf-8
